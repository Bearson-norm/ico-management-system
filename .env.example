# Salin ke .env dan sesuaikan. URL harus sama dengan user/sandi yang ADA di server PostgreSQL Anda.

# --- Lokal + Docker Compose (user dev / sandi devpassword — lihat docker-compose.yml) ---
DATABASE_URL_MTC="postgresql://dev:devpassword@127.0.0.1:5432/mtc_db"
DATABASE_URL_GA="postgresql://dev:devpassword@127.0.0.1:5432/ga_db"

# --- VPS / Postgres native (ganti USER, PASSWORD, port, nama DB sesuai server Anda) ---
# Contoh jika role Postgres Anda bernama postgres:
# DATABASE_URL_MTC="postgresql://postgres:SANDI_ANDA@127.0.0.1:5432/mtc_db"
# DATABASE_URL_GA="postgresql://postgres:SANDI_ANDA@127.0.0.1:5432/ga_db"
# Port DB bukan 5432? Ganti angka di URL (mis. 1357).

NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="ganti-dengan-string-random-panjang"

# Produksi di belakang nginx + HTTPS (sesuaikan domain)
# NEXTAUTH_URL="https://msic.moof-set.web.id"
# HOST=127.0.0.1
# PORT=1325
